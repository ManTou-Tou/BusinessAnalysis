# 复制为 .env 后填入真实值（本地开发）
APP_ENV=development

# MySQL（本地安装，默认 localhost:3306）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=Subaru
MYSQL_PASSWORD=123456
MYSQL_DB=dev

# Redis（本地安装，Celery broker/backend）
REDIS_URL=redis://localhost:6379/0

# 连接池（Phase 8）—— 留空用默认值（与既往硬编码一致）
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_RECYCLE=1800   # 秒

# 批量导入（Phase 8）—— 留空用默认值
# REVIEW_IMPORT_MAX_PER_REQUEST=5000  # 单次评论导入上限，超出返回 400 提示分批
# BULK_INSERT_CHUNK_SIZE=1000         # 单事务内每次 executemany 行数

# API 限流（Phase 8：Redis 固定窗口，fail-open）—— 留空用默认值
# RATELIMIT_ENABLED=true
# RATELIMIT_DEFAULT_LIMIT=60          # 默认每窗口请求数（写/CRUD）
# RATELIMIT_DEFAULT_WINDOW_S=60       # 窗口秒数
# RATELIMIT_LLM_TRIGGER_LIMIT=20      # LLM 触发/导入类更紧额度

# 分布式锁（Phase 8）—— 留空用默认值
# DISPATCH_LOCK_TTL_S=600             # Beat 派发锁 TTL（秒）

# Excel 导入（Phase 9）—— 留空用默认值
# IMPORT_UPLOAD_DIR=var/imports       # 上传落盘目录（相对 backend，不在 web 根）
# IMPORT_MAX_FILE_BYTES=20971520      # 单文件上限（20MB）
# IMPORT_MAX_ROW_ERRORS=200           # 行级错误明细上限（超出只计数）

# 利润计算（Phase 6，确定性）—— 留空用默认值
# PROFIT_MAX_ORDERS_PER_RUN=1000   # 单次 compute 任务最多处理订单数
# PROFIT_CALC_VERSION=v1           # 利润口径版本（进幂等键 + 审计）；口径升级时 bump 触发重算

# 日报（Phase 7：确定性聚合 + LLM 仅总结）—— 留空用默认值
# LLM_MODEL_REPORT=claude-sonnet-4-6  # 报告总结模型（Sonnet）
# REPORT_CALC_VERSION=v1              # 日报口径/prompt 版本（进幂等键 + 审计）
# REPORT_TOP_N=5                      # top / low_profit 商品取前 N
# REPORT_LOW_PROFIT_MARGIN=0.10      # 低利润净利率阈值
# REPORT_NEGATIVE_SAMPLE=20          # 喂 LLM 的负面评论条数上限

# LLM (Claude)
# 占位符——复制为 .env 后填入真实 key；切勿把真实 key 提交进 .env.example
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
